# Optional DashScope key for demos that use developer ASR/TTS.
DASHSCOPE_API_KEY=

# Broadcast demo
BROADCAST_HTTP_PORT=8081
PRODUCTS_CONFIG_PATH=config/crypto_market.example.yaml

# Chat demo
HTTP_PORT=8080

# Teaching / talkshow demos
TEACHING_HTTP_PORT=8082
TALKSHOW_HTTP_PORT=8082
