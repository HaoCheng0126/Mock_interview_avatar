# LiveAvatar platform credentials
LIVEAVATAR_API_KEY=
LIVEAVATAR_AVATAR_ID=
LIVEAVATAR_BASE_URL=https://liveavatar.aimiai.com/vih/dispatcher
LIVEAVATAR_VOICE_ID=

# LLM provider (answer evaluation / follow-up decisions / final report).
# Defaults target DeepSeek's OpenAI-compatible endpoint.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# DashScope key for realtime speech recognition (Qwen ASR).
# Leave empty to fall back to platform-side ASR.
DASHSCOPE_API_KEY=

# Interview agent
INTERVIEW_HTTP_PORT=8083
INTERVIEW_CONFIG_PATH=config/interview.yaml

# Hub console
HUB_PORT=8000
