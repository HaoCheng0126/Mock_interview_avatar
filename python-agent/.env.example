# LiveAvatar platform credentials
LIVEAVATAR_API_KEY=
LIVEAVATAR_AVATAR_ID=
LIVEAVATAR_BASE_URL=https://facemarket.ai/vih/dispatcher
LIVEAVATAR_VOICE_ID=
# Route sessions to the sandbox environment (30 free minutes/month): true/false
LIVEAVATAR_SANDBOX=
# Platform TTS speaking speed 0.5-2.0; empty = avatar default.
# Note: the avatar must have platform TTS enabled in the LiveAvatar console,
# otherwise text responses will not drive the avatar.
LIVEAVATAR_VOICE_SPEED=

# LLM provider (answer evaluation / follow-up decisions / final report).
# Defaults target DeepSeek's OpenAI-compatible endpoint.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Speech recognition (ASR) — REQUIRED for voice answers. In WebSocket Agent
# mode ASR is always developer-provided (no platform fallback); without it
# candidates can only answer by text.
# Provider: "dashscope" (Aliyun Qwen) or "volcengine" (豆包语音).
ASR_PROVIDER=dashscope

# DashScope Qwen realtime ASR
DASHSCOPE_API_KEY=

# Volcengine streaming ASR (豆包语音 · 流式语音识别).
# Copy VOLC_ASR_CLUSTER from the console service-detail page
# (通用 / 粤语 / 川渝 are different clusters). The console's Secret Key is not
# used by this WebSocket stream, so it has no env var here.
VOLC_ASR_APP_ID=
VOLC_ASR_ACCESS_TOKEN=
VOLC_ASR_CLUSTER=volcengine_streaming_common

# Interview agent
INTERVIEW_HTTP_PORT=8083
INTERVIEW_CONFIG_PATH=config/interview.yaml

# Hub console
HUB_PORT=8000
